    def show_disclaimer(self):
        disclaimer_text = self.load_disclaimer_from_csv('Disclaimer.csv')
        disclaimer_text += "\n\nFor support, contact: NL7PA@example.com"
        messagebox.showinfo("Disclaimer", disclaimer_text)

    def load_disclaimer_from_csv(self, file_path):
        disclaimer_text = ""
        try:
            with open(file_path, mode='r') as file:
                reader = csv.reader(file)
                for row in reader:
                    disclaimer_text += " ".join(row) + "\n"
        except FileNotFoundError:
            disclaimer_text = "Disclaimer.csv not found. Please ensure the file is in the correct directory."
        return disclaimer_text.strip()

    def load_regions_from_csv(self, file_path):
        regions = {}
        try:
            with open(file_path, mode='r') as file:
                reader = csv.reader(file)
                for row in reader:
                    if len(row) == 2:
                        regions[row[0]] = row[1]
        except FileNotFoundError:
            messagebox.showerror("File Not Found", f"{file_path} not found. Please ensure the file is in the correct directory.")
        return regions

    def generate_row(self, index):
        new_row = ["", "", "", "Absent", "", "", "", "0"]
        return new_row

    def reset_application(self):
        if not self.tree.get_children():
            messagebox.showinfo("Nothing to reset", "No data is currently loaded.")
            return
        if not messagebox.askyesno("Confirm Reset",
                                  "This will clear ALL data, timers, net control, sweepers,\n"
                                  "visitor count, and unsaved changes.\n\n"
                                  "Are you sure you want to reset everything?"):
            return
        # Clear table
        self.tree.delete(*self.tree.get_children())
        # Clear sweepers
        self.sweepers_tree.delete(*self.sweepers_tree.get_children())
        # Reset important state variables
        self.data = []
        self.unsaved_changes = False
        self.stopwatch_running = False
        self.first_alert_triggered = False
        self.status_counts = {"Absent": 0, "Present": 0, "Excused": 0}
        self.total_call_sign_count = 0
        self.visitor_count = 0
        self.net_control = ""
        self.current_net_name = ""
        self.time_start = None
        self.time_end = None
        self.stopwatch_start_time = None
        self.present_today = set()
        self.loaded_file_name = None
        # Reset UI elements
        self.start_stop_button.config(text="Start Roll Call", bg="green")
        self.stopwatch_label.config(text="", bg="green")
        self.start_info_label.config(text="")
        self.results_label.config(text="Application reset")
        self.stats_text_view.config(state=tk.NORMAL)
        self.stats_text_view.delete(1.0, tk.END)
        self.stats_text_view.config(state=tk.DISABLED)
        # Hide data-dependent buttons
        self.refresh_button.pack_forget()
        self.reset_button.pack_forget()
        self.update_clock()
        self.update_results_label("Application has been reset — ready for new session")

