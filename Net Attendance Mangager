        self.start_info_label.config(bg=bg_color, fg=fg_color)
        self.results_label.config(bg=bg_color, fg=fg_color)
        self.stats_label.config(bg=bg_color, fg=fg_color)
        self.stats_text_view.config(bg=bg_color, fg=fg_color)
