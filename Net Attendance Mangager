    def sort_column(self, col, ascending=True):
        col_idx = self.columns.index(col)
        data = [(self.tree.set(child, col), child) for child in self.tree.get_children('')]
        if col in ["Call Sign", "QTH", "Name"]:
            data.sort(key=lambda x: str(x[0]), reverse=not ascending)
        elif col in ["This Month"]:
            data.sort(key=lambda x: int(x[0]) if x[0].isdigit() else float('inf'), reverse=not ascending)
        else:
            data.sort(reverse=not ascending)
        for index, (_, child) in enumerate(data):
            self.tree.move(child, '', index)
        self.tree.heading(col, command=lambda: self.sort_column(col, not ascending))
        self.apply_separator_style()

    def cycle_search_windows(self, event, search_window):
        if not self.search_windows:
            return
        try:
            current_index = self.search_windows.index(search_window)
        except ValueError:
            return
        self.current_search_index = (current_index + 1) % len(self.search_windows)
        next_window = self.search_windows[self.current_search_index]
        next_window.lift()
        for widget in next_window.winfo_children():
            if isinstance(widget, tk.Entry):
                widget.focus_set()
                break
        return "break"

    def search_table(self):
        if not self.tree.get_children():
            messagebox.showwarning("No Data", "The table is empty. Please load data first.")
            return
        search_window = tk.Toplevel(self.root)
        search_window.title("Search Table")
        search_window.geometry("400x200")
        search_window.resizable(False, False)
        search_window.transient(self.root)
        self.search_windows.append(search_window)
        self.current_search_index = len(self.search_windows) - 1
        self.root.update_idletasks()
        search_width = 400
        search_height = 200
        if self.last_search_window_position:
            last_x, last_y = self.last_search_window_position
            x = last_x + 20
            y = last_y + 20
        else:
            main_x = self.root.winfo_x()
            main_y = self.root.winfo_y()
            main_width = self.root.winfo_width()
            main_height = self.root.winfo_height()
            x = main_x + (main_width // 2) - (search_width // 2)
            y = main_y + (main_height // 2) - (search_height // 2)
        search_window.geometry(f"{search_width}x{search_height}+{x}+{y}")
        self.last_search_window_position = (x, y)
        search_window.lift()
        tk.Label(search_window, text="Enter search terms (separated by commas):", font=("Arial", 12)).pack(pady=10)
        search_entry = tk.Entry(search_window, width=50, font=("Arial", 12))
        search_entry.pack(pady=10)
        search_entry.focus_set()
        def perform_search():
            search_input = search_entry.get()
            if not search_input:
                self.turn_caps_lock_off()
                return
            search_terms = [term.strip().lower() for term in search_input.split(',') if term.strip()]
            if not search_terms:
                self.turn_caps_lock_off()
                return
            self.tree.selection_remove(*self.tree.selection())
            found = False
            matched_items = []
            for item in self.tree.get_children():
                values = self.tree.item(item, "values")
                row_values = [str(values[i]).lower() for i in range(3)]
                if any(any(term in value for value in row_values) for term in search_terms):
                    matched_items.append(item)
                    found = True
            if matched_items:
                for item in matched_items:
                    self.tree.selection_add(item)
                self.tree.focus(matched_items[0])
                self.tree.see(matched_items[0])
                self.update_results_label(f"Found {len(matched_items)} matching row(s)")
            if not found:
                add_new = messagebox.askyesno("No Results", "No results found. Add a new row with the first search term?", parent=search_window)
                if add_new:
                    self.add_new_row_with_search_query(search_terms[0])
            self.turn_caps_lock_off()
            search_entry.delete(0, tk.END)
        def close_search_window():
            self.turn_caps_lock_off()
            try:
                self.search_windows.remove(search_window)
                if self.current_search_index >= len(self.search_windows):
                    self.current_search_index = len(self.search_windows) - 1
            except ValueError:
                pass
            search_window.destroy()
        button_frame = tk.Frame(search_window)
        button_frame.pack(pady=10)
        tk.Button(button_frame, text="Search", command=perform_search, bg="green", fg="white", width=10).pack(side=tk.LEFT, padx=5)
        tk.Button(button_frame, text="Close", command=close_search_window, bg="red", fg="white", width=10).pack(side=tk.LEFT, padx=5)
        search_window.bind("<Return>", lambda event: perform_search())
        search_window.bind("<Tab>", lambda event: self.cycle_search_windows(event, search_window))
        if self.dark_mode:
            search_window.config(bg="black")
            for widget in search_window.winfo_children():
                widget.config(bg="black", fg="white")
                if isinstance(widget, tk.Frame):
                    for child in widget.winfo_children():
                        child.config(bg="black", fg="white")

