    def load_preamble_text(self, net_type="rollcall"):
        """
        Load preamble from CSV file depending on net type.
          - "rollcall" → PreambleRollCallNet.csv
          - "open" → PreambleOpenNet.csv
        """
        if net_type.lower() == "open":
            filename = "PreambleOpenNet.csv"
        else:
            filename = "PreambleRollCallNet.csv"
        try:
            with open(filename, mode='r', encoding='utf-8') as f:
                reader = csv.reader(f)
                lines = []
                for row in reader:
                    cleaned = " ".join(cell.strip() for cell in row if cell.strip())
                    if cleaned:
                        lines.append(cleaned)
                if lines:
                    return "\n\n".join(lines)
                else:
                    return "(Preamble file is empty)"
        except FileNotFoundError:
            return f"Could not find {filename} in the working directory."
        except Exception as e:
            return f"Error reading {filename}: {str(e)}"

