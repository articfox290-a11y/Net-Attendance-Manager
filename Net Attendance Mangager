    def validate_call_sign(self, call_sign):
        call_sign = call_sign.strip().upper()

        # Basic US Amateur Radio call sign pattern:
        # 1–2 letters, 1 number, 1–3 letters (e.g., K7ABC, KL5XYZ, W1AW)
        pattern = r"^[A-Z]{1,2}\d[A-Z]{1,3}$"

        if re.match(pattern, call_sign):
            return call_sign
        else:
            messagebox.showerror(
                "Invalid Call Sign",
                "Enter a valid US Amateur Call Sign.\n\n"
                "Format: 1–2 letters, a number, then 1–3 letters\n"
                "Examples: K7ABC, KL5XYZ, W1AW"
            )
            return None

